[sub_resource type="GDScript" id="GDScript_nh7pe"]
script/source = "extends Node2D
## Tutorial area - The player's first explorable space after the intro.
## Here they learn movement and can interact with the Bard again.

@onready var player: Player = $Player
@onready var bard: Bard = $Bard
@onready var camera: Camera2D = $Player/Camera2D
@onready var tutorial_ui: CanvasLayer = $TutorialUI
@onready var hint_label: Label = $TutorialUI/HintLabel

var has_shown_movement_hint: bool = false
var has_moved: bool = false
var has_shown_interact_hint: bool = false


func _ready() -> void:
	# Start with screen black and fade in
	SceneTransition.start_black()
	
	# Connect signals
	if bard:
		bard.dialogue_started.connect(_on_bard_dialogue_started)
		bard.dialogue_ended.connect(_on_bard_dialogue_ended)
	
	# Short delay then fade in and show tutorial
	await get_tree().create_timer(0.5).timeout
	await SceneTransition.fade_in(1.5)
	
	# Show movement hint after fade completes
	await get_tree().create_timer(1.0).timeout
	_show_movement_hint()


func _physics_process(_delta: float) -> void:
	if not has_moved and player:
		# Check if player has moved
		if player.velocity.length() > 0:
			has_moved = true
			_on_player_moved()


func _show_movement_hint() -> void:
	if has_shown_movement_hint:
		return
	has_shown_movement_hint = true
	hint_label.text = \"Use ARROW KEYS or WASD to move\"
	hint_label.modulate.a = 0.0
	
	var tween = create_tween()
	tween.tween_property(hint_label, \"modulate:a\", 1.0, 0.5)


func _on_player_moved() -> void:
	# Fade out movement hint
	var tween = create_tween()
	tween.tween_property(hint_label, \"modulate:a\", 0.0, 1.0)
	await tween.finished
	
	# Show interact hint after a moment
	await get_tree().create_timer(2.0).timeout
	_show_interact_hint()


func _show_interact_hint() -> void:
	if has_shown_interact_hint:
		return
	has_shown_interact_hint = true
	hint_label.text = \"Press SPACE or ENTER near the Bard to talk\"
	
	var tween = create_tween()
	tween.tween_property(hint_label, \"modulate:a\", 1.0, 0.5)


func _on_bard_dialogue_started() -> void:
	# Hide hint and freeze player during dialogue
	var tween = create_tween()
	tween.tween_property(hint_label, \"modulate:a\", 0.0, 0.3)
	
	if player:
		player.freeze()


func _on_bard_dialogue_ended() -> void:
	if player:
		player.unfreeze()
"

