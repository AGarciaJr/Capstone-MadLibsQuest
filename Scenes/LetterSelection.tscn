[gd_scene format=3 uid="uid://cu41gsvqwuar8"]

[sub_resource type="GDScript" id="GDScript_story_intro"]
script/source = "extends Control

signal intro_complete(player_name: String, starting_letters: Array[String])

enum State { GREETING, ASK_NAME, ASK_LETTERS, CONFIRM }

var current_state: State = State.GREETING
var player_name: String = \"\"
var selected_letters: Array[String] = []

const BARD_DIALOGUES = {
	State.GREETING: \"Ah, a new adventurer! Welcome, welcome! I am the Bard, keeper of tales and singer of songs. Your legend shall be written in verse!\",
	State.ASK_NAME: \"But first, I must know... what name shall echo through the ages? What do they call you, brave soul?\",
	State.ASK_LETTERS: \"Splendid! Now, every hero begins their journey with trusted companions. Choose 5 letters to be your starting characters. These letters will power your words in battle!\",
	State.CONFIRM: \"\"
}

const LETTER_DIALOGUES = {
	\"A\": \"A! The first of all letters! Bold and ready to lead.\",
	\"B\": \"B! Bold and brave, built for battle!\",
	\"C\": \"C! Confident and cunning, always one step ahead.\",
	\"D\": \"D! Determined and daring, never backing down.\",
	\"E\": \"E! Eager and elegant, never ordinary.\",
	\"F\": \"F! Fast and fierce, striking fear into their foes\",
	\"G\": \"G! Genuine and grounded, steady in all storms.\",
	\"H\": \"H! Humble, but heroic, dependable when it counts.\",
	\"I\": \"I! Inventive and illustrious, one of a kind.\",
	\"J\": \"J! Joyful and jesting, a wildcard in any situation.\",
	\"K\": \"K! Kind and knowledgeable, sharp when it matters.\",
	\"L\": \"L! Lazy, but likeable, never underestimate a slow starter.\",
	\"M\": \"M! Mighty and mindful, full of purpose.\",
	\"N\": \"N! Noble and nurturing, steadfast in their objective.\",
	\"O\": \"O! Optimistic and orderly, the glue that holds words together.\",
	\"P\": \"P! Powerful and precise, hits hard and true.\",
	\"Q\": \"Q! Quirky, yet quiet, says little, but has deep meaning.\",
	\"R\": \"R! Relentless and rowdy, never stops fighting.\",
	\"S\": \"S! Swift and strong, the backbone of many words.\",
	\"T\": \"T! Tenacious and thorough, trusted in battle.\",
	\"U\": \"U! Unstoppable and unique, shows up when needed.\",
	\"V\": \"V! Valiant and versatile, fights without fear.\",
	\"W\": \"W! Wise and witty, always knows what to say.\",
	\"X\": \"X! One of the most exotic and exceptional.\",
	\"Y\": \"Y! Youthful and yielding, adaptable in many ways.\",
	\"Z\": \"Z! Zealous and zippy, the last letter, but definitely not least.\",
}

func _ready() -> void:
	AudioPlayer.play_music_level()
	_update_ui()
	$VBoxContainer/NameInput.visible = false
	$VBoxContainer/LetterInput.visible = false
	$VBoxContainer/SelectedLetters.visible = false
	$VBoxContainer/HBoxContainer/RemoveButton.visible = false
	$VBoxContainer/HBoxContainer/ContinueButton.grab_focus()

func _update_ui() -> void:
	if current_state == State.CONFIRM:
		$VBoxContainer/DialogueLabel.text = \"Excellent, %s! With the letters %s at your side, your adventure begins! May your words strike true!\" % [player_name, \", \".join(selected_letters)]
	else:
		$VBoxContainer/DialogueLabel.text = BARD_DIALOGUES[current_state]
	
	$VBoxContainer/SelectedLetters.text = \"Selected Letters: \" + \", \".join(selected_letters) + \" (%d/5)\" % selected_letters.size()

func _on_remove_button_pressed() -> void:
	if selected_letters.is_empty():
		$VBoxContainer/DialogueLabel.text = \"You haven't chosen any letters yet!\"
		return
	var removed = selected_letters.pop_back()
	_update_ui()
	$VBoxContainer/DialogueLabel.text = \"'%s' has left the party.\" % removed
	$VBoxContainer/LetterInput.grab_focus()

func _on_continue_button_pressed() -> void:
	match current_state:
		State.GREETING:
			current_state = State.ASK_NAME
			$VBoxContainer/NameInput.visible = true
			$VBoxContainer/NameInput.grab_focus()
			$VBoxContainer/HBoxContainer/ContinueButton.text = \"Confirm Name\"
		State.ASK_NAME:
			var input_name = $VBoxContainer/NameInput.text.strip_edges()
			if input_name.is_empty():
				$VBoxContainer/DialogueLabel.text = \"Come now, surely you have a name? Don't be shy!\"
				return
			player_name = input_name
			$VBoxContainer/NameInput.visible = false
			current_state = State.ASK_LETTERS
			$VBoxContainer/LetterInput.visible = true
			$VBoxContainer/SelectedLetters.visible = true
			$VBoxContainer/HBoxContainer/RemoveButton.visible = true
			$VBoxContainer/LetterInput.grab_focus()
			$VBoxContainer/HBoxContainer/ContinueButton.text = \"Begin Adventure\"
		State.ASK_LETTERS:
			# Player must choose 5 starting letters
			if selected_letters.size() < 5:
				$VBoxContainer/DialogueLabel.text = \"Choose all 5 letter companions before continuing! You have %d so far.\" % selected_letters.size()
				return
			current_state = State.CONFIRM
			$VBoxContainer/LetterInput.visible = false
			$VBoxContainer/HBoxContainer/ContinueButton.text = \"Start Quest!\"
		State.CONFIRM:
			intro_complete.emit(player_name, selected_letters)
			# Save data and go to the room
			PlayerState.player_name = player_name
			PlayerState.set_initial_player_letters(PackedStringArray(selected_letters))
			get_tree().change_scene_to_file(Scenes.ROOM)
	
	_update_ui()

func _on_letter_input_text_submitted(new_text: String) -> void:
	_add_letter(new_text)
	$VBoxContainer/LetterInput.clear()

func _add_letter(text: String) -> void:
	var letter = text.strip_edges().to_upper()
	if letter.length() != 1 or not letter[0] in \"ABCDEFGHIJKLMNOPQRSTUVWXYZ\":
		return
	if letter in selected_letters:
		$VBoxContainer/DialogueLabel.text = \"You've already chosen '%s'! Pick a different letter.\" % letter
		return
	if selected_letters.size() >= 5:
		$VBoxContainer/DialogueLabel.text = \"You can only have 5 letter companions!\"
		return
	
	selected_letters.append(letter)
	_update_ui()
	var line = LETTER_DIALOGUES.get(letter, \"A fine choice of companion!\")
	$VBoxContainer/DialogueLabel.text = \"%s '%s' joins your party!\" % [line, letter]

func _on_letter_input_text_changed(new_text: String) -> void:
	# Auto-submit single letters
	if new_text.length() == 1:
		_add_letter(new_text)
		$VBoxContainer/LetterInput.clear()
		
"

